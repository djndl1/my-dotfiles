function java-debug-args {
    echo "-agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=$1"
}

function mono-debug {
    address=$1
    shift
    mono --debug --debugger-agent=transport=dt_socket,server=y,address=${address} "$@"
}

