{
    "layer": "bottom",
    "position": "top",
    "height": 24,
    "modules-left": ["sway/workspaces"],
    "modules-right": ["clock", "cpu", "memory", "network#1", "network#2", "temperature", "battery", "tray"],
    "sway/workspaces": {
      "on-click": "activate",
      "sort-by-number": true
    },
    "clock": {
	"format": "<span font=\"Cascadia Mono\">{:%Y-%m-%d %H:%M:%S}</span>",
	"interval": 1
    },
    "cpu": {
	"interval": 2,
	"format": "<span font=\"Cascadia Mono\">CPU{usage:3}%</span>"
    },
    "memory": {
	"interval": 2,
        "format": "<span font=\"Cascadia Mono\">Mem {used:0.1f}GiB</span>"
    },
    "temperature": {
	"thermal-zone": 0,
        "interval": 2
    },
    "battery": {
        "format": "{capacity:3}% {icon}",
        "format-alt": "{time} {icon}",
        "format-icons": ["", "", "", "", ""],
        "format-charging": "{capacity}% ",
        "interval": 30,
        "states": {
            "warning": 25,
            "critical": 10
        },
        "tooltip": false
    },
    "network#1": {
	"format": "<span font=\"Cascadia Mono\">{essid} ⬆️{bandwidthUpBytes:>} ⬇️{bandwidthDownBytes:>}</span>",
        "format-alt": "{ipaddr}/{cidr} {icon}",
        "format-alt-click": "click-right",
	"interface": "wlp1s0",
        "format-icons": {
            "wifi": [""],
            "ethernet": [""],
            "disconnected": [""]
        },
	"interval": 2,
    	"tooltip": false
    },
    "network#2": {
	"format": "<span font=\"Cascadia Mono\">{icon} ⬆️{bandwidthUpBytes:>} ⬇️{bandwidthDownBytes:>}</span>",
        "format-alt": "{ipaddr}/{cidr} {icon}",
        "format-alt-click": "click-right",
	"interface": "enx2c16dba6713a",
        "format-icons": {
            "wifi": [""],
            "ethernet": [""],
            "disconnected": [""]
        },
	"interval": 2,
    	"tooltip": false
    },
    "network#3": {
	"format": "<span font=\"Cascadia Mono\">{icon} ⬆️{bandwidthUpBytes:>} ⬇️{bandwidthDownBytes:>}</span>",
        "format-alt": "{ipaddr}/{cidr} {icon}",
        "format-alt-click": "click-right",
	"interface": "eth0",
        "format-icons": {
            "wifi": [""],
            "ethernet": [""],
            "disconnected": [""]
        },
	"interval": 2,
    	"tooltip": false
    },
    "tray": {
    	"icon-size": 18
    }
}
